########################################
# Optional: Vertex AI / Google GenAI (if not using GEMINI_API_KEY only)
########################################
# GOOGLE_GENAI_API_KEY=your-google-genai-api-key
# VERTEX_AI=true
# GOOGLE_CLOUD_PROJECT=PROJECT_ID
# GOOGLE_CLOUD_LOCATION=PROJECT_LOCATION
# GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account.json

########################################
# Google Gemini (BeeAI Framework)
########################################
GEMINI_API_KEY=your-gemini-api-key
GEMINI_CHAT_MODEL=gemini-3-pro-preview

########################################
# A2A remote agents (TypeScript servers or other backends)
########################################
POLICY_AGENT_PORT=9999
RESEARCH_AGENT_PORT=9998
FIND_PROVIDERS_AGENT_PORT=9997

########################################
# dotenv runtime behavior
########################################
DOTENV_CONFIG_QUIET=true

########################################
# Healthcare Concierge AgentStack servers (listen ports + registered names)
########################################
HEALTHCARE_CONCIERGE_AGENTSTACK_PORT=9996
POLICY_AGENTSTACK_PORT=8887
RESEARCH_AGENTSTACK_PORT=8889
FIND_PROVIDERS_AGENTSTACK_PORT=8890

POLICY_AGENTSTACK_NAME="Policy Agent"
RESEARCH_AGENTSTACK_NAME="Research Agent"
FIND_PROVIDERS_AGENTSTACK_NAME="Find Providers Agent"

